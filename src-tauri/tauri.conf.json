{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrabCademy",
  "version": "0.1.0",
  "identifier": "com.nicholasfinch.crab-cademy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "additionalWatchFolders": []
  },
  "app": {
    "windows": [
      {
        "title": "CrabCademy",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/lessons/*",
      "../polars_runner/Cargo.toml",
      "../polars_runner/src/**/*"
    ]
  }
}